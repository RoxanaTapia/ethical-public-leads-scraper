# Python / Bytecode / Packaging
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments & secrets (never commit)
.env
.env.*
!.env.example
.venv
venv/
ENV/

# Streamlit (only ignore secrets/local config)
.streamlit/secrets.toml
.streamlit/config.toml  # only if it contains secrets

# Vector stores & large regeneratable caches (critical for RAG/FAISS)
*.faiss
*.index
index.faiss
index.pkl
chroma/
*.chroma
.huggingface/
.cache/huggingface/

# Data & temporary files (don't commit real PDFs or client data)
data/
samples/
uploaded/
tmp/
temp/
*.log

# IDE / editor files (add only what you actually use)
.vscode/
.idea/
.cursor/
!.cursor/rules/
!.cursor/rules/*.mdc

# Testing & coverage (add when you start writing tests)
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# OS junk
.DS_Store
Thumbs.db
